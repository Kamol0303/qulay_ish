# Firebase (required in production)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIRESTORE_DATABASE_ID=

# Optional
VITE_USE_EMULATOR=false
VITE_SHOW_DEBUG_BANNER=false
VITE_ALLOW_OTP_LOCAL_SESSION=false

# Super Admin (required for /super-admin-login)
VITE_SUPER_ADMIN_PHONE=
VITE_SUPER_ADMIN_PASSWORD=
VITE_SUPER_ADMIN_EMAIL=

# Payment providers (optional)
VITE_PAYME_MERCHANT_ID=
VITE_PAYME_ENABLED=false
VITE_CLICK_MERCHANT_ID=
VITE_CLICK_SERVICE_ID=
VITE_CLICK_ENABLED=false
VITE_UZUM_MERCHANT_ID=
VITE_UZUM_ENABLED=false
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_STRIPE_ENABLED=false

# AI assistant (optional)
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-3.5-turbo
VITE_OPENAI_ENABLED=false
VITE_ANTHROPIC_API_KEY=
VITE_ANTHROPIC_MODEL=claude-3-sonnet
VITE_ANTHROPIC_ENABLED=false
VITE_AI_MOCK_MODE=true
