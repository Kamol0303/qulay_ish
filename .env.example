VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Named Firestore DB — Firebase Console → Firestore → top bar database name
# Example (do not use "(default)" if your project uses a named database):
VITE_FIRESTORE_DATABASE_ID=ai-studio-4c1b1226-dd9d-4904-bc52-80793df46787

# Backend export / migration scripts (optional, same values as above)
FIREBASE_PROJECT_ID=gen-lang-client-0528497200
FIRESTORE_DATABASE_ID=ai-studio-4c1b1226-dd9d-4904-bc52-80793df46787
# FIREBASE_SERVICE_ACCOUNT — set in GitHub/Cursor Secrets (full JSON), not in this file

# Optional
VITE_USE_EMULATOR=false
VITE_SHOW_DEBUG_BANNER=false
VITE_ALLOW_OTP_LOCAL_SESSION=false

# Super Admin (required for /super-admin-login)
VITE_SUPER_ADMIN_PHONE=
