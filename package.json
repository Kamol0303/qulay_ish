{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "seed:workers": "tsx scripts/addWorkerProfiles.ts",
    "migrate:passwords": "tsx scripts/migratePasswords.ts",
    "db:up": "sh -c 'docker compose up -d postgres 2>/dev/null || docker-compose up -d postgres'",
    "db:down": "sh -c 'docker compose down 2>/dev/null || docker-compose down'",
    "api:install": "cd api && npm install",
    "api:dev": "cd api && npm run start:dev",
    "api:build": "cd api && npm run build",
    "db:migrate": "cd api && npx prisma migrate dev",
    "db:seed": "cd api && npm run prisma:seed",
    "export:firestore": "cd api && npm run export:firestore"
  },
  "dependencies": {
    "@dataconnect/generated": "file:src/dataconnect-generated",
    "@tailwindcss/vite": "^4.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.14.0",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.2",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
