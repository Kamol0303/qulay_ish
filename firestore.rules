rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // HELPER FUNCTIONS
    // ============================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isDemoUser(uid) {
      return uid.matches('demo_(worker|employer)_.*');
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() in ['admin', 'super_admin'];
    }

    function isSuperAdmin() {
      return isAuthenticated() && getUserRole() == 'super_admin';
    }

    function isWorker() {
      return isAuthenticated() && getUserRole() == 'worker';
    }

    function isEmployer() {
      return isAuthenticated() && getUserRole() == 'employer';
    }

    // ============================================
    // PROFILES COLLECTION
    // ============================================
    match /profiles/{uid} {
      // Read: Anyone can read profiles
      allow read: if true;
      
      // Create: DEMO MODE (demo_worker_*) OR Authenticated users
      allow create: if isDemoUser(uid) || 
                       (isOwner(uid) && isAuthenticated());
      
      // Update: Demo users OR Owner OR Admin
      allow update: if isDemoUser(uid) ||
                       isOwner(uid) ||
                       isAdmin();
      
      // Delete: Only super_admin can delete profiles
      allow delete: if isSuperAdmin();
    }

    // ============================================
    // JOBS COLLECTION
    // ============================================
    match /jobs/{jobId} {
      // Read: Public (anyone can view jobs)
      allow read: if true;
      
      // Create: Authenticated users (typically employers)
      allow create: if isAuthenticated();
      
      // Update: Job owner or admin
      allow update: if isAuthenticated() &&
        (resource.data.employerId == request.auth.uid || isAdmin());
      
      // Delete: Job owner, admin, or super_admin
      allow delete: if isAuthenticated() &&
        (resource.data.employerId == request.auth.uid || isAdmin());
    }

    // ============================================
    // APPLICATIONS COLLECTION
    // ============================================
    match /applications/{applicationId} {
      // Read: Worker, employer involved, or admin
      allow read: if isAuthenticated() &&
        (resource.data.workerId == request.auth.uid ||
         resource.data.employerId == request.auth.uid ||
         isAdmin());
      
      // Create: Authenticated workers applying
      allow create: if isAuthenticated() &&
        request.resource.data.workerId == request.auth.uid;
      
      // Update: Worker or employer involved, or admin
      allow update: if isAuthenticated() &&
        (resource.data.workerId == request.auth.uid ||
         resource.data.employerId == request.auth.uid ||
         isAdmin());
      
      // Delete: Admin or super_admin only
      allow delete: if isAdmin();
    }

    // ============================================
    // SERVICE POSTS COLLECTION
    // ============================================
    match /service_posts/{postId} {
      // Read: Public
      allow read: if true;
      
      // Create: Authenticated users (workers)
      allow create: if isAuthenticated() &&
        request.resource.data.workerId == request.auth.uid;
      
      // Update: Post owner or admin
      allow update: if isAuthenticated() &&
        (resource.data.workerId == request.auth.uid || isAdmin());
      
      // Delete: Post owner or admin
      allow delete: if isAuthenticated() &&
        (resource.data.workerId == request.auth.uid || isAdmin());
    }

    // ============================================
    // CONTRACTS COLLECTION
    // ============================================
    match /contracts/{contractId} {
      // Read: Worker, employer involved, or admin
      allow read: if isAuthenticated() &&
        (resource.data.workerId == request.auth.uid ||
         resource.data.employerId == request.auth.uid ||
         isAdmin());
      
      // Create: Authenticated users (typically employers)
      allow create: if isAuthenticated();
      
      // Update: Worker or employer involved, or admin
      allow update: if isAuthenticated() &&
        (resource.data.workerId == request.auth.uid ||
         resource.data.employerId == request.auth.uid ||
         isAdmin());
      
      // Delete: Super admin only
      allow delete: if isSuperAdmin();
    }

    // ============================================
    // CHAT MESSAGES COLLECTION
    // ============================================
    match /chat_messages/{messageId} {
      // Read: Sender or receiver only
      allow read: if isAuthenticated() &&
        (resource.data.senderId == request.auth.uid ||
         resource.data.receiverId == request.auth.uid ||
         isAdmin());
      
      // Create: Authenticated users (must be sender)
      allow create: if isAuthenticated() &&
        request.resource.data.senderId == request.auth.uid;
      
      // Update: Sender only (for marking as read, etc.)
      allow update: if isAuthenticated() &&
        (resource.data.senderId == request.auth.uid ||
         resource.data.receiverId == request.auth.uid);
      
      // Delete: Admin or super_admin only
      allow delete: if isAdmin();
    }

    // ============================================
    // NOTIFICATIONS COLLECTION
    // ============================================
    match /notifications/{notificationId} {
      // Read: Owner of notification only (or admin)
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      
      // Create: System can create (any authenticated user for now)
      // In production, this should be server-side only
      allow create: if isAuthenticated();
      
      // Update: Owner can mark as read
      allow update: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      
      // Delete: Owner or admin
      allow delete: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ============================================
    // DISPUTES COLLECTION
    // ============================================
    match /disputes/{disputeId} {
      // Read: Dispute raiser or admin
      allow read: if isAuthenticated() &&
        (resource.data.openedById == request.auth.uid || isAdmin());
      
      // Create: Authenticated users
      allow create: if isAuthenticated() &&
        request.resource.data.openedById == request.auth.uid;
      
      // Update: Admin only (for resolution)
      allow update: if isAdmin();
      
      // Delete: Super admin only
      allow delete: if isSuperAdmin();
    }

    // ============================================
    // VERIFICATION REQUESTS COLLECTION
    // ============================================
    match /verification_requests/{requestId} {
      // Read: Request owner or admin
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      
      // Create: Authenticated users
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      
      // Update: Admin only (for approval/rejection)
      allow update: if isAdmin();
      
      // Delete: Super admin only
      allow delete: if isSuperAdmin();
    }

    // ============================================
    // EMPLOYMENT STATS COLLECTION
    // ============================================
    match /employment_stats/{statId} {
      // Read: Public (for platform statistics)
      allow read: if true;
      
      // Write: Admin or super_admin only
      allow write: if isAdmin();
    }

    // ============================================
    // SYSTEM LOGS COLLECTION
    // ============================================
    match /system_logs/{logId} {
      // Read: Admin or super_admin only
      allow read: if isAdmin();
      
      // Create: Any authenticated user (for audit trail)
      allow create: if isAuthenticated();
      
      // Update/Delete: Super admin only
      allow update, delete: if isSuperAdmin();
    }

    // ============================================
    // SYSTEM CONFIG COLLECTION
    // ============================================
    match /system_config/{configId} {
      // Read: Admin or super_admin
      allow read: if isAdmin();
      
      // Write: Super admin only
      allow write: if isSuperAdmin();
    }

    // ============================================
    // PAYMENTS COLLECTION (Future)
    // ============================================
    match /payments/{paymentId} {
      // Read: Payment owner or admin
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      
      // Create: Authenticated users
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      
      // Update: System only (webhook) or admin
      // In production, this should be server-side only
      allow update: if isAdmin();
      
      // Delete: Super admin only
      allow delete: if isSuperAdmin();
    }

    // ============================================
    // TRANSACTIONS COLLECTION (Future)
    // ============================================
    match /transactions/{transactionId} {
      // Read: Transaction owner or admin
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      
      // Create: System only (should be server-side)
      allow create: if isAdmin();
      
      // Update: Admin only
      allow update: if isAdmin();
      
      // Delete: Super admin only
      allow delete: if isSuperAdmin();
    }

    // ============================================
    // REVIEWS COLLECTION (Future)
    // ============================================
    match /reviews/{reviewId} {
      // Read: Public
      allow read: if true;
      
      // Create: Authenticated users
      allow create: if isAuthenticated() &&
        request.resource.data.reviewerId == request.auth.uid;
      
      // Update: Review owner or admin
      allow update: if isAuthenticated() &&
        (resource.data.reviewerId == request.auth.uid || isAdmin());
      
      // Delete: Review owner or admin
      allow delete: if isAuthenticated() &&
        (resource.data.reviewerId == request.auth.uid || isAdmin());
    }

    // ============================================
    // ACTIVITY LOGS COLLECTION
    // ============================================
    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isSuperAdmin();
    }

    // ============================================
    // ONLINE USERS COLLECTION
    // ============================================
    match /online_users/{docId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isSuperAdmin();
    }

    // ============================================
    // SAVED JOBS COLLECTION (Qulay Ish)
    // ============================================
    match /savedJobs/{savedJobId} {
      // Read: User can read their own saved jobs, admin can read all
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      
      // Create: User can save jobs for themselves
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      
      // Update: Not allowed (saved jobs are immutable except deletion)
      allow update: if false;
      
      // Delete: User can remove their own saved jobs, or admin can delete
      allow delete: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ============================================
    // OTP SESSIONS COLLECTION
    // ============================================
    match /otp_sessions/{sessionId} {
      allow create: if request.resource.data.sessionId == sessionId;
      allow get, update: if true;
      allow list, delete: if isAdmin();
    }

    // ============================================
    // VIOLATIONS COLLECTION
    // ============================================
    match /violations/{violationId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // ============================================
    // GLOBAL SETTINGS COLLECTION
    // ============================================
    match /settings/{configId} {
      allow read: if isAdmin();
      allow write: if isSuperAdmin();
    }

    // ============================================
    // SYSTEM STATS COLLECTION
    // ============================================
    match /system_stats/{statId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ============================================
    // DEFAULT DENY
    // ============================================
    // Any collection not explicitly defined above is denied by default
  }
}
